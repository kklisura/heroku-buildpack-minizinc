#!/usr/bin/env bash
# Invoke with `source "$BUILDPACK_DIR/bin/install-minizinc"` from inside `bin/compile`.
# This script is mostly copied from:
#  https://github.com/heroku/heroku-buildpack-google-chrome/blob/master/bin/compile

# Uses variables & methods from compile script:
# BUILD_DIR
# CACHE_DIR
# ENV_DIR
# BUILDPACK_DIR
# topic()
# indent()

MZN_VERSION="2.9.4"
MZN_DIR="MiniZincIDE-${MZN_VERSION}-bundle-linux-x86_64"
MZN_ARCHIVE="${MZN_DIR}.tgz"
MZN_BIN_DIR=minizinc

INSTALL_DIR="$BUILD_DIR/.bin"

## Create the installation directory if it does not exist
mkdir -p $INSTALL_DIR

## Download MiniZinc release
wget "https://github.com/MiniZinc/MiniZincIDE/releases/download/${MZN_VERSION}/${MZN_ARCHIVE}" \
     -nv -O "${INSTALL_DIR}/${MZN_ARCHIVE}"

## Extract the binaries from archive
tar xf "${INSTALL_DIR}/${MZN_ARCHIVE}" -C "${INSTALL_DIR}"

## Remove extracted directory
rm "${INSTALL_DIR}/${MZN_ARCHIVE}"

# Create a symlink
cd "${INSTALL_DIR}"
ln -s "${MZN_DIR}/bin" "${INSTALL_DIR}/${MZN_BIN_DIR}"

export PATH="${INSTALL_DIR}/${MZN_BIN_DIR}:$PATH"

#give environment to later buildpacks
export | grep -E -e ' (PATH)='  > "$BUILDPACK_DIR/export"

echo "Installed MiniZinc" | indent

cat <<EOF >$BUILD_DIR/.profile.d/001_minizinc_buildpack_paths.sh
export PATH="/app/.bin/${MZN_BIN_DIR}:$PATH"
EOF